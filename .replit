modules = ["web", "bash", "python-3.11"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Jupyter Lab"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash preview.sh"
waitForPort = 5000

[[workflows.workflow]]
name = "Jupyter Lab"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "jupyter lab --ip=0.0.0.0 --port=8080 --no-browser --ServerApp.token='' --ServerApp.password='' --ServerApp.allow_origin='*' --ServerApp.disable_check_xsrf=True"
waitForPort = 8080

[workflows.workflow.metadata]
outputType = "console"

[deployment]
deploymentTarget = "static"
build = ["quarto", "render"]
publicDir = "_site"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080
